<!--
 Migrated schema for modern Solr (9.x / 10.x).
 Migrated from a Solr 4-era schema with the stock product-catalog example
 fields removed and the application's custom fields preserved.

 Schema version 1.7 defaults:
   - docValues defaults to true on supported types
   - uninvertible defaults to false
   - useDocValuesAsStored defaults to true
-->

<schema name="app-schema" version="1.7">

    <!-- =====================================================================
         REQUIRED / SYSTEM FIELDS
         ===================================================================== -->

    <!-- Primary key. Keep type=string so it is stored verbatim (no tokenization). -->
    <field name="id" type="string" indexed="true" stored="true" required="true" multiValued="false"/>

    <!-- Required by Solr's update log and SolrCloud's optimistic concurrency.
         docValues is enabled by default on plong, so we don't need to index/store. -->
    <field name="_version_" type="plong" indexed="false" stored="false"/>

    <!-- Nested document support. Remove these two if you don't use child documents. -->
    <field name="_root_" type="string" indexed="true" stored="false"/>
    <field name="_nest_path_" type="_nest_path_"/>
    <fieldType name="_nest_path_" class="solr.NestPathField"/>

    <!-- Catch-all searchable text field (modern convention). Populated via copyField below. -->
    <field name="_text_" type="text_general" indexed="true" stored="false" multiValued="true"/>

    <!-- Legacy catch-all field, kept for backward compatibility with clients
         (e.g. WSO2 Carbon Registry) that were written against the Solr 4-era
         schema where the catch-all was named "text" instead of "_text_".
         Do not remove unless you have confirmed no client writes to this field
         name. -->
    <field name="text" type="text_general" indexed="true" stored="false" multiValued="true"/>


    <!-- =====================================================================
         APPLICATION FIELDS (custom fields carried over from the old schema)
         ===================================================================== -->

    <!-- Tenant isolation. Filter every query with fq=tenantId:<id>. -->
    <field name="tenantId" type="pint" indexed="true" stored="true"/>

    <!-- Per-document role-based access control.
         Filter queries with fq=allowedRoles:(role1 role2 ...). -->
    <field name="allowedRoles" type="string" indexed="true" stored="false" multiValued="true"/>

    <!-- Auto-stamped at index time if not supplied by the client. -->
    <field name="timestamp" type="pdate" indexed="true" stored="true" default="NOW" multiValued="false"/>

    <!-- English-analyzed body of the document. Use this for full-text search. -->
    <field name="contentOnly" type="text_en" indexed="true" stored="true"/>

    <!-- Stored-but-not-indexed full body extracted by Tika / SolrCell.
         Used for returning the original text and for highlighting.
         Searching is done via the contentOnly / _text_ fields instead. -->
    <field name="content" type="text_general" indexed="false" stored="true" multiValued="true"/>

    <!-- Optional: keyword tag used by the application. Kept as string for
         exact matching, faceting, and grouping. -->
    <field name="word" type="string" indexed="true" stored="true"/>


    <!-- =====================================================================
         COPY FIELDS
         ===================================================================== -->

    <!-- Send searchable text into the catch-all _text_ field so a simple
         q=foo query matches across any of the listed sources. -->
    <copyField source="contentOnly" dest="_text_"/>
    <copyField source="content"     dest="_text_"/>
    <copyField source="word"        dest="_text_"/>


    <!-- =====================================================================
         UNIQUE KEY
         ===================================================================== -->
    <uniqueKey>id</uniqueKey>


    <!-- =====================================================================
         DYNAMIC FIELDS
         Naming-convention shortcuts so the application can index new fields
         without editing the schema. Suffix decides the type.
         ===================================================================== -->

    <!-- Numeric (Point-based KD-tree indexes) -->
    <dynamicField name="*_i"   type="pint"     indexed="true" stored="true"/>
    <dynamicField name="*_is"  type="pints"    indexed="true" stored="true"/>
    <dynamicField name="*_l"   type="plong"    indexed="true" stored="true"/>
    <dynamicField name="*_ls"  type="plongs"   indexed="true" stored="true"/>
    <dynamicField name="*_f"   type="pfloat"   indexed="true" stored="true"/>
    <dynamicField name="*_fs"  type="pfloats"  indexed="true" stored="true"/>
    <dynamicField name="*_d"   type="pdouble"  indexed="true" stored="true"/>
    <dynamicField name="*_ds"  type="pdoubles" indexed="true" stored="true"/>

    <!-- Boolean -->
    <dynamicField name="*_b"   type="boolean"  indexed="true" stored="true"/>
    <dynamicField name="*_bs"  type="booleans" indexed="true" stored="true"/>

    <!-- String (not analyzed: exact match, sort, facet) -->
    <dynamicField name="*_s"   type="string"   indexed="true" stored="true"/>
    <dynamicField name="*_ss"  type="strings"  indexed="true" stored="true"/>

    <!-- Date -->
    <dynamicField name="*_dt"  type="pdate"    indexed="true" stored="true"/>
    <dynamicField name="*_dts" type="pdates"   indexed="true" stored="true"/>

    <!-- Text (full-text analyzed) -->
    <dynamicField name="*_t"   type="text_general" indexed="true" stored="true" multiValued="false"/>
    <dynamicField name="*_txt" type="text_general" indexed="true" stored="true"/>

    <!-- DocValues-only string companion for text fields, useful for faceting/sorting. -->
    <dynamicField name="*_str" type="strings"  stored="false" docValues="true" indexed="false" useDocValuesAsStored="false"/>

    <!-- Prefix-style convenience field for arbitrary attributes. -->
    <dynamicField name="attr_*" type="text_general" indexed="true" stored="true" multiValued="true"/>

    <!-- Catch-all for fields that should be silently dropped. -->
    <dynamicField name="ignored_*" type="ignored"/>

    <!-- Pseudo-random sort order tied to the index version. -->
    <dynamicField name="random_*" type="random"/>


    <!-- =====================================================================
         FIELD TYPES — PRIMITIVES
         ===================================================================== -->

    <!-- String: indexed/stored verbatim, no analysis. -->
    <fieldType name="string"  class="solr.StrField" sortMissingLast="true"/>
    <fieldType name="strings" class="solr.StrField" sortMissingLast="true" multiValued="true"/>

    <!-- Boolean. -->
    <fieldType name="boolean"  class="solr.BoolField" sortMissingLast="true"/>
    <fieldType name="booleans" class="solr.BoolField" sortMissingLast="true" multiValued="true"/>

    <!-- Point-based numeric types (replace the old Trie* types). -->
    <fieldType name="pint"    class="solr.IntPointField"/>
    <fieldType name="pfloat"  class="solr.FloatPointField"/>
    <fieldType name="plong"   class="solr.LongPointField"/>
    <fieldType name="pdouble" class="solr.DoublePointField"/>
    <fieldType name="pints"   class="solr.IntPointField"    multiValued="true"/>
    <fieldType name="pfloats" class="solr.FloatPointField"  multiValued="true"/>
    <fieldType name="plongs"  class="solr.LongPointField"   multiValued="true"/>
    <fieldType name="pdoubles" class="solr.DoublePointField" multiValued="true"/>

    <!-- Date (UTC ISO-8601, supports NOW math like NOW/DAY-7DAYS). -->
    <fieldType name="pdate"  class="solr.DatePointField"/>
    <fieldType name="pdates" class="solr.DatePointField" multiValued="true"/>

    <!-- Binary (base64 wire format). -->
    <fieldType name="binary" class="solr.BinaryField"/>

    <!-- Pseudo-random sort key. -->
    <fieldType name="random" class="solr.RandomSortField" indexed="true"/>

    <!-- Silently dropped values. -->
    <fieldType name="ignored" stored="false" indexed="false" multiValued="true" docValues="false" class="solr.StrField"/>


    <!-- =====================================================================
         FIELD TYPES — TEXT ANALYZERS
         ===================================================================== -->

    <!-- Generic text: StandardTokenizer + stopwords + lowercase.
         Query-time synonyms only (so the index stays compact). -->
    <fieldType name="text_general" class="solr.TextField" positionIncrementGap="100" multiValued="true">
      <analyzer type="index">
        <tokenizer name="standard"/>
        <filter name="stop" ignoreCase="true" words="stopwords.txt"/>
        <filter name="lowercase"/>
      </analyzer>
      <analyzer type="query">
        <tokenizer name="standard"/>
        <filter name="stop" ignoreCase="true" words="stopwords.txt"/>
        <filter name="synonymGraph" synonyms="synonyms.txt" ignoreCase="true" expand="true"/>
        <filter name="lowercase"/>
      </analyzer>
    </fieldType>

    <!-- English: stop words, possessive stripping, Porter stemming. -->
    <fieldType name="text_en" class="solr.TextField" positionIncrementGap="100">
      <analyzer type="index">
        <tokenizer name="standard"/>
        <filter name="stop" ignoreCase="true" words="lang/stopwords_en.txt"/>
        <filter name="lowercase"/>
        <filter name="englishPossessive"/>
        <filter name="keywordMarker" protected="protwords.txt"/>
        <filter name="porterStem"/>
      </analyzer>
      <analyzer type="query">
        <tokenizer name="standard"/>
        <filter name="synonymGraph" synonyms="synonyms.txt" ignoreCase="true" expand="true"/>
        <filter name="stop" ignoreCase="true" words="lang/stopwords_en.txt"/>
        <filter name="lowercase"/>
        <filter name="englishPossessive"/>
        <filter name="keywordMarker" protected="protwords.txt"/>
        <filter name="porterStem"/>
      </analyzer>
    </fieldType>

</schema>
